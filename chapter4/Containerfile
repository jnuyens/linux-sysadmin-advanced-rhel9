# Containerfile for Chapter 4 exercise - simple Python web app
# Uses Red Hat UBI 9 as base image

FROM registry.access.redhat.com/ubi9/python-311

LABEL maintainer="sysadmin-course"
LABEL description="Simple Python web app for container exercises"

WORKDIR /app

COPY app.py .

EXPOSE 5000

# Run as non-root user
USER 1001

CMD ["python3", "app.py"]
